# Supabase Settings
NEXT_PUBLIC_APP_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox Settings
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# API Keys for Data Fetching
OPENWEATHER_API_KEY=
OPENAQ_API_KEY=
GOOGLE_API_KEY=

# Sentinel Hub (Satellite Imagery)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# NASA FIRMS API (Fire Information for Resource Management System)
# Get a free key at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_nasa_firms_api_key

# --- Web Push Notifications ---
# Generate these using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key
VAPID_PRIVATE_KEY=your_private_vapid_key
VAPID_SUBJECT=mailto:admin@example.com

# --- Security & Cron ---
# Used to secure your cron endpoints (e.g., /api/cron/*)
# Use a long, random string.
CRON_SECRET=your_cron_secret_password
